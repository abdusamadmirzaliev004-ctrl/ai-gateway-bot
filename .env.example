# --- Telegram ---
BOT_TOKEN=123456:ABC-your-bot-token

# Webhook (production). Leave WEBHOOK_URL empty to use long polling (dev only).
# Example: WEBHOOK_URL=https://your-app.up.railway.app
WEBHOOK_URL=
WEBHOOK_PATH=/tg/webhook
WEBHOOK_SECRET=change-me-random
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080

# --- Database ---
# SQLite default — for Railway Postgres set:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# --- Admin ---
# Comma-separated Telegram user IDs
ADMIN_IDS=

# --- Defaults ---
DEFAULT_PROVIDER=github_copilot
DEFAULT_MODE=fast

# --- Quotas ---
DAILY_MESSAGE_LIMIT=50
DAILY_TOKEN_LIMIT=100000
RATE_LIMIT_PER_MINUTE=10

# --- Fallback chain (comma-separated provider keys) ---
FALLBACK_CHAIN=github_copilot,openai,anthropic

# --- Provider credentials (fill what you use) ---

# GitHub Copilot Pro+ (REQUIRED for the Copilot models)
GITHUB_COPILOT_TOKEN=
GITHUB_COPILOT_ENDPOINT=https://api.githubcopilot.com/chat/completions

# OpenAI native
OPENAI_API_KEY=

# Anthropic native
ANTHROPIC_API_KEY=

# Google Gemini native
GOOGLE_API_KEY=

# xAI Grok
XAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_REFERER=https://github.com/your/repo
OPENROUTER_TITLE=AI Gateway Bot
